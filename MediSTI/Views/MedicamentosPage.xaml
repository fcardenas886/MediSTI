<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediSTI.Views.MedicamentosPage"
             BackgroundColor="#F2F2F2">

    <Grid RowDefinitions="Auto, *, Auto" Padding="15">

        <!-- CABECERA: Perfil del Paciente -->
        <Border Grid.Row="0" 
                BackgroundColor="#1967B3" 
                StrokeShape="RoundRectangle 20"
                Padding="20"
                Margin="0,0,0,15"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="👤" FontSize="30" Margin="0,0,10,0"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label x:Name="lblNombrePaciente" 
                           TextColor="White" 
                           FontSize="20" 
                           FontAttributes="Bold"/>
                    <Label Text="Paciente Registrado" 
                           TextColor="White" 
                           FontSize="12" 
                           Opacity="0.8"/>
                </VerticalStackLayout>

                <Label Grid.Column="2" 
                       Text="MediSTI" 
                       TextColor="White" 
                       FontSize="11" 
                       VerticalOptions="Center"
                       FontAttributes="Italic"/>
            </Grid>
        </Border>

        <!-- LISTA DE MEDICAMENTOS -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Medicamentos}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 20" 
                            Margin="0,0,0,15" 
                            Padding="18" 
                            BackgroundColor="White"
                            StrokeThickness="0">
                        <VerticalStackLayout Spacing="12">

                            <!-- Línea Superior: Ícono, Nombre y Menú de Opciones -->
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label Grid.Column="0" Text="💊" FontSize="18" Margin="0,0,8,0"/>

                                <Label Grid.Column="1" 
                                    Text="{Binding Nombre}" 
                                    FontAttributes="Bold" 
                                    FontSize="18" 
                                    TextColor="#333"
                                    VerticalOptions="Center"/>

                                <HorizontalStackLayout Grid.Column="2" Spacing="8">
                                    <!-- Badge de Activo -->
                                    <Frame BackgroundColor="#E3F2FD" Padding="8,2" CornerRadius="10" HasShadow="False" BorderColor="Transparent">
                                        <Label Text="Activo" TextColor="#1967B3" FontSize="10" FontAttributes="Bold"/>
                                    </Frame>

                                    <!-- LOS TRES PUNTITOS -->
                                    <Label Text="⋮" 
                                        FontSize="24" 
                                        TextColor="Gray" 
                                        VerticalOptions="Center" 
                                         Padding="10,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnOpcionesMedicamentoTapped" 
                                      CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </HorizontalStackLayout>
                            </Grid>

                            <!-- Triple Columna: Dosis, Frecuencia, Vigencia -->
                            <Grid ColumnDefinitions="*, *, *">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="DOSIS" FontSize="10" TextColor="#BBB" FontAttributes="Bold"/>
                                    <Label Text="{Binding Dosis}" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="FRECUENCIA" FontSize="10" TextColor="#BBB" FontAttributes="Bold"/>
                                    <Label Text="{Binding Frecuencia}" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="End">
                                    <Label Text="VIGENCIA" FontSize="10" TextColor="#BBB" FontAttributes="Bold" HorizontalTextAlignment="End"/>
                                    <Label Text="{Binding FechaFin, StringFormat='{0:dd MMM}'}" 
                                           FontSize="13" 
                                           FontAttributes="Bold" 
                                           TextColor="#333"
                                           HorizontalTextAlignment="End"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Horarios Reales: Burbujas dinámicas -->
                            <FlexLayout BindableLayout.ItemsSource="{Binding ListaHorarios}" 
                                        Wrap="Wrap" 
                                        Direction="Row" 
                                        Margin="0,5">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Frame BackgroundColor="#E8F2FB" 
                                               Padding="10,4" 
                                               CornerRadius="12" 
                                               HasShadow="False" 
                                               Margin="0,0,5,5"
                                               BorderColor="Transparent">
                                            <Label Text="{Binding Hora, StringFormat='{0:hh\\:mm}'}" 
                                                   FontSize="11" 
                                                   TextColor="#1967B3" 
                                                   FontAttributes="Bold"/>
                                        </Frame>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>

                            <!-- Días de la semana -->
                            <!-- Busca la sección del calendario y reemplázala por esta -->
                            <HorizontalStackLayout Spacing="8" Margin="0,5,0,0">
                                <Label Text="🗓️" FontSize="14" VerticalOptions="Center"/>
                                <Label Text="{Binding DiasSemana}" 
                                FontSize="12" 
           TextColor="#1967B3" 
           FontAttributes="Bold"
           VerticalOptions="Center"></Label>

                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- BOTÓN DE ACCIÓN -->
        <Button Grid.Row="2"
                Text="+ Registrar Medicamento"
                Clicked="OnAgregarMedicinaClicked"
                BackgroundColor="#1967B3"
                TextColor="White"
                HeightRequest="60"
                CornerRadius="15"
                FontAttributes="Bold"
                FontSize="16"
                Margin="0,10,0,0"/>
    </Grid>
</ContentPage>