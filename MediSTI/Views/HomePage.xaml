<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediSTI.ViewModels"
             xmlns:models="clr-namespace:MediSTI.Models"
             x:Class="MediSTI.Views.HomePage"
             Title="MediSTI - Inicio"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" 
          Padding="20" 
          RowSpacing="15">

        <Label x:Name="VersionLabel" Grid.Row="0" FontSize="10" TextColor="Gray" HorizontalOptions="End"/>

        <Border x:Name="MostrarBannerPermisos" Grid.Row="1" IsVisible="False" BackgroundColor="Orange" StrokeShape="RoundRectangle 10">
            <VerticalStackLayout Padding="12">
                <Label Text="⚠️ Configura permisos de notificaciones" FontAttributes="Bold" TextColor="Black"/>
                <Button Text="Configurar ahora" Clicked="OnConfigurarPermisos" Margin="0,8,0,0"/>
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="2" Spacing="5" HorizontalOptions="Center">
            <Image Source="dotnet_bot.png" HeightRequest="80" />
            <Label Text="¿Qué necesitas recordar?" FontSize="20" FontAttributes="Bold" />
        </VerticalStackLayout>

        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12" HeightRequest="50">
            <!-- ALARMA EXPRESS -->
            <Button Grid.Column="0"
                    Text="⏰ ALARMA EXPRESS"
                    Command="{Binding AlarmaRapidaCommand}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="12"
                    CornerRadius="10"/>

            <!-- DIAGNÓSTICO -->
            <Button Grid.Column="1"
                    Text="🛠️ DIAGNÓSTICO"
                    Clicked="OnDiagnosticoClicked"
                    BackgroundColor="#E8F0FE"
                    TextColor="#1967B3"
                    BorderColor="#1967B3"
                    BorderWidth="1"
                    FontAttributes="Bold"
                    FontSize="12"
                    CornerRadius="10"/>
        </Grid>

        <Border Grid.Row="4" StrokeShape="RoundRectangle 16" BackgroundColor="White" Stroke="#E0E0E0" Padding="12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Grid.Column="0" Text="⏳" FontSize="28" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0">
                    <Label Text="{Binding ProximoTexto}" FontAttributes="Bold" FontSize="14"/>
                    <Label Text="{Binding CuentaRegresiva}" FontSize="20" FontAttributes="Bold" TextColor="#1E88E5"/>
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="Agenda" Command="{Binding VerAgendaCompletaCommand}" FontSize="10" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- TARJETA DE ADHERENCIA DIARIA (Progreso) -->
        <Border Grid.Row="5" 
                StrokeShape="RoundRectangle 16" 
                BackgroundColor="White" 
                Stroke="#E0E0E0" 
                Padding="15"
                IsVisible="{Binding TieneTomas}">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="📈 Adherencia de Hoy" FontAttributes="Bold" FontSize="14" TextColor="#555"/>
                    <Label Grid.Column="1" Text="{Binding ProgresoTexto}" FontSize="12" FontAttributes="Bold" TextColor="#1E88E5"/>
                </Grid>
                <ProgressBar Progress="{Binding ProgresoTomas}" ProgressColor="#27AE60" HeightRequest="8"/>
            </VerticalStackLayout>
        </Border>

        <Label Grid.Row="6" Text="📅 Próximas tomas de hoy" FontSize="18" FontAttributes="Bold" />

        <CollectionView Grid.Row="7" ItemsSource="{Binding TomasDeHoy}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TomaDelDia">
                    <Border Padding="14" Margin="0,6" BackgroundColor="White" Stroke="#E0E0E0" StrokeShape="RoundRectangle 14">
                        <Grid ColumnDefinitions="*,Auto,Auto">

                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding MedicamentoNombre}" FontAttributes="Bold" FontSize="16" TextColor="#185FA5"/>
                                <Label Text="{Binding NombrePaciente, StringFormat='Paciente: {0}'}" FontSize="12" TextColor="#777"/>
                                <Label Text="{Binding Dosis, StringFormat='Dosis: {0}'}" FontSize="12" FontAttributes="Italic"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" MinimumWidthRequest="80">
                                <Label Text="{Binding HoraFormateada}" FontSize="20" FontAttributes="Bold" TextColor="{Binding ColorEstado}" HorizontalOptions="End"/>
                                <Label Text="{Binding TiempoRestante}" FontSize="13" TextColor="Red" FontAttributes="Bold" HorizontalOptions="End"/>
                                <Label Text="{Binding IconoEstado}" FontSize="18" HorizontalOptions="End" Margin="0,2,0,0"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                    Text="Tomar"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=MarcarTomadaCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#27AE60"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    Padding="10,0"
                                    HeightRequest="40"
                                    VerticalOptions="Center"
                                    Margin="10,0,0,0">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding YaTomada}" Value="True">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>