<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediSTI.Views.DiagnosticoPage"
             Title="Diagnóstico de Alertas"
             BackgroundColor="#F5F7FA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <!-- Encabezado -->
            <Frame BackgroundColor="#1967B3" Padding="15" CornerRadius="10" HasShadow="False">
                <VerticalStackLayout Spacing="5">
                    <Label Text="🛠️ Diagnóstico de Alertas" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                    <Label Text="Verifica que el teléfono permita recibir las notificaciones de medicamentos a tiempo." TextColor="#E0F0FF" FontSize="12"/>
                </VerticalStackLayout>
            </Frame>

            <!-- 1. Permiso de Notificaciones -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" BackgroundColor="White" Padding="15">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="5">
                    <Label Grid.Row="0" Grid.Column="0" x:Name="lblNotifIcon" Text="❓" FontSize="24" Margin="0,0,10,0" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Permiso de Notificaciones" FontAttributes="Bold" FontSize="14"/>
                        <Label x:Name="lblNotifStatus" Text="Cargando..." FontSize="12" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                    <Button Grid.Row="0" Grid.Column="2" x:Name="btnNotifAction" Text="Configurar" Clicked="OnRequestNotifClicked" FontSize="11" Padding="10,0" HeightRequest="35" VerticalOptions="Center"/>
                    
                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="Necesario para mostrar los avisos visuales y alertas sonoras en tu pantalla." TextColor="Gray" FontSize="11" Margin="0,5,0,0"/>
                </Grid>
            </Border>

            <!-- 2. Alarmas Exactas -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" BackgroundColor="White" Padding="15">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="5">
                    <Label Grid.Row="0" Grid.Column="0" x:Name="lblExactIcon" Text="❓" FontSize="24" Margin="0,0,10,0" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Alarmas de Precisión (Exactas)" FontAttributes="Bold" FontSize="14"/>
                        <Label x:Name="lblExactStatus" Text="Cargando..." FontSize="12" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                    <Button Grid.Row="0" Grid.Column="2" x:Name="btnExactAction" Text="Habilitar" Clicked="OnRequestExactClicked" FontSize="11" Padding="10,0" HeightRequest="35" VerticalOptions="Center"/>
                    
                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="Permite que las alarmas suenen exactamente en el minuto configurado, omitiendo la restricción de retrasos del sistema." TextColor="Gray" FontSize="11" Margin="0,5,0,0"/>
                </Grid>
            </Border>

            <!-- 3. Optimización de Batería -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" BackgroundColor="White" Padding="15">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="5">
                    <Label Grid.Row="0" Grid.Column="0" x:Name="lblBatteryIcon" Text="❓" FontSize="24" Margin="0,0,10,0" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Optimización de Batería" FontAttributes="Bold" FontSize="14"/>
                        <Label x:Name="lblBatteryStatus" Text="Cargando..." FontSize="12" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                    <Button Grid.Row="0" Grid.Column="2" x:Name="btnBatteryAction" Text="Ajustar" Clicked="OnRequestBatteryClicked" FontSize="11" Padding="10,0" HeightRequest="35" VerticalOptions="Center"/>
                    
                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="Recomendado: 'Sin Restricciones' o 'Excluir'. Evita que Android duerma el servicio de recordatorios cuando el teléfono está inactivo." TextColor="Gray" FontSize="11" Margin="0,5,0,0"/>
                </Grid>
            </Border>

            <!-- 4. Inicio Automático y Segundo Plano (Info) -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" BackgroundColor="White" Padding="15">
                <VerticalStackLayout Spacing="5">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚙️" FontSize="24" VerticalOptions="Center"/>
                        <Label Text="Ajustes de Marca (Xiaomi, Huawei, etc.)" FontAttributes="Bold" FontSize="14" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Si tu dispositivo cierra las aplicaciones en segundo plano de manera agresiva:" TextColor="#E06900" FontAttributes="Bold" FontSize="11" Margin="0,5,0,0"/>
                    <Label Text="1. Habilita el 'Inicio Automático' (Autostart) para MediSTI.&#10;2. En Ahorro de batería de la app, selecciona 'Sin restricciones'." TextColor="Gray" FontSize="11"/>
                    <Button Text="Abrir Ajustes de la Aplicación" Clicked="OnOpenAppSettingsClicked" Margin="0,10,0,0" BackgroundColor="Transparent" BorderColor="#1967B3" BorderWidth="1" TextColor="#1967B3" HeightRequest="40"/>
                </VerticalStackLayout>
            </Border>

            <!-- Botones de Acción inferior -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                <Button Grid.Column="0" Text="Re-evaluar" Clicked="OnReevaluarClicked" BackgroundColor="#1967B3" TextColor="White" HeightRequest="45" CornerRadius="10"/>
                <Button Grid.Column="1" Text="Cerrar" Clicked="OnCerrarClicked" BackgroundColor="Transparent" BorderColor="Gray" BorderWidth="1" TextColor="Gray" HeightRequest="45" CornerRadius="10"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
