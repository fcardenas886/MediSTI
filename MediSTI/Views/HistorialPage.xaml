<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediSTI.ViewModels"
             xmlns:models="clr-namespace:MediSTI.Models"
             x:Class="MediSTI.Views.HistorialPage"
             Title="MediSTI - Historial de Tomas"
             x:DataType="vm:RegistrosViewModel"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="15">

        <!-- CABECERA -->
        <Border Grid.Row="0" 
                BackgroundColor="#1967B3" 
                StrokeShape="RoundRectangle 20"
                Padding="20"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto, *">
                <Label Grid.Column="0" Text="📋" FontSize="30" Margin="0,0,15,0" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Historial de Medicación" 
                           TextColor="White" 
                           FontSize="20" 
                           FontAttributes="Bold"/>
                    <Label Text="Registro cronológico de tomas completadas" 
                           TextColor="White" 
                           FontSize="12" 
                           Opacity="0.8"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- LISTADO DE HISTORIAL -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Registros}">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="40">
                    <Label Text="📭" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="No hay tomas registradas aún." TextColor="Gray" HorizontalOptions="Center" FontAttributes="Bold"/>
                    <Label Text="Las tomas que confirmes aparecerán aquí." TextColor="DarkGray" HorizontalOptions="Center" FontSize="12"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:RegistroDetalle">
                    <Border StrokeShape="RoundRectangle 15" 
                            Margin="0,0,0,12" 
                            Padding="15" 
                            BackgroundColor="White"
                            StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <!-- Icono -->
                            <Label Grid.Column="0" Text="💊" FontSize="24" VerticalOptions="Center" Margin="0,0,12,0"/>

                            <!-- Detalles -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding MedicamentoNombre}" FontAttributes="Bold" FontSize="16" TextColor="#333"/>
                                <Label Text="{Binding Dosis, StringFormat='Dosis: {0}'}" FontSize="12" TextColor="#666"/>
                                <Label Text="{Binding PacienteNombre, StringFormat='Paciente: {0}'}" FontSize="12" TextColor="#1967B3" FontAttributes="Bold"/>
                                <Label Text="{Binding Notas}" FontSize="10" TextColor="#888" FontAttributes="Italic"/>
                            </VerticalStackLayout>

                            <!-- Hora y Estado -->
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center" Spacing="4">
                                <Frame BackgroundColor="#E8F8F5" Padding="8,3" CornerRadius="8" BorderColor="Transparent" HasShadow="False" HorizontalOptions="End">
                                    <Label Text="{Binding Estado}" TextColor="#27AE60" FontSize="11" FontAttributes="Bold"/>
                                </Frame>
                                <Label Text="{Binding FechaHoraFormateada}" FontSize="11" TextColor="Gray" HorizontalTextAlignment="End"/>
                                <Label Text="{Binding HoraProgramadaFormateada, StringFormat='Prog: {0}'}" FontSize="10" TextColor="#888" HorizontalTextAlignment="End"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>