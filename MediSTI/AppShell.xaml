<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:MediSTI.Views"
       x:Class="MediSTI.AppShell"> 

    <TabBar>

        <Tab Title="Home" Icon="casa.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}"/>
        </Tab>

        <Tab Title="Pacientes" Icon="paciente.png">
            <ShellContent ContentTemplate="{DataTemplate views:PacientesPage}"/>
        </Tab>

        <Tab Title="Farmacias Turno" Icon="farmacia.png">
            <ShellContent ContentTemplate="{DataTemplate views:FarmaciasPage}"/>
        </Tab>

        <Tab Title="Historial" Icon="historial.png">
            <ShellContent ContentTemplate="{DataTemplate views:HistorialPage}"/>
        </Tab>

    </TabBar>

</Shell>
